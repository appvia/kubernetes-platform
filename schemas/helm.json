{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Helm addon manifest",
  "description": "YAML file containing a list of platform Helm addon definitions",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "category",
      "description",
      "feature",
      "namespace",
      "repository",
      "version"
    ],
    "properties": {
      "feature": {
        "type": "string",
        "minLength": 1
      },
      "repository": {
        "type": "string",
        "minLength": 1
      },
      "namespace": {
        "type": "string",
        "minLength": 1
      },
      "version": {
        "type": "string",
        "minLength": 1
      },
      "category": {
        "$ref": "addon-category.json"
      },
      "description": {
        "type": "string",
        "minLength": 1
      },
      "link": {
        "type": "string",
        "minLength": 1
      }
    },
    "additionalProperties": true
  }
}
